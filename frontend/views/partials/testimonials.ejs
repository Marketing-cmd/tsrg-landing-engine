<section class="tsrg-section tsrg-proof" aria-label="Client testimonials">
  <div class="tsrg-container">
    <h2 class="tsrg-section-title"><%= content.socialProof.headline %></h2>
    <div class="tsrg-testimonial-grid">
      <% content.socialProof.testimonials.forEach(function(testimonial) { %>
        <figure class="tsrg-testimonial">
          <blockquote><%= testimonial.quote %></blockquote>
          <figcaption><%= testimonial.author %> · <%= testimonial.location %></figcaption>
        </figure>
      <% }); %>
    </div>
  </div>
</section>
